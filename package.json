{
  "name": "ts-reconf",
  "version": "0.4.5",
  "description": "Understand and simplify (re-conf) your tsconfig.json",
  "main": "index.js",
  "type": "module",
  "bin": {
    "ts-reconf": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rockcoder/ts-reconf.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "tsconfig",
    "cli",
    "developer-tools"
  ],
  "author": "rockcoder",
  "license": "MIT",
  "dependencies": {
    "typescript": "7.0.2"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.23.1",
    "vitest": "4.1.10"
  }
}
