{
  "name": "ts-reconf",
  "version": "0.4.1",
  "description": "Understand and simplify (re-conf) your tsconfig.json",
  "main": "index.js",
  "type": "module",
  "bin": {
    "ts-reconf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rockcoder/ts-reconf.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "typescript",
    "tsconfig",
    "cli",
    "developer-tools"
  ],
  "author": "rockcoder",
  "license": "MIT",
  "dependencies": {
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "tsx": "4.22.4",
    "vitest": "4.1.8"
  }
}
